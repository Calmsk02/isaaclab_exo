<launch>

<rosparam file="$(find isaac_humanbody_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="isaac_humanbody" args="waist_position_controller left_shoulder_position_controller left_elbow_position_controller right_shoulder_position_controller right_elbow_position_controller left_hip_position_controller left_knee_position_controller left_ankle_position_controller right_hip_position_controller right_knee_position_controller right_ankle_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/isaac_humanbody/joint_states"/>
</node>

</launch>